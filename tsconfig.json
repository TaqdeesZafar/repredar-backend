{
    "compilerOptions": {
      "target": "ES6",                 
      "module": "commonjs",            
      "strict": true,                  
      "esModuleInterop": true,        
      "skipLibCheck": true,           
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "rootDir": "./",
      "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "api/**/*.ts"],
    "exclude": ["node_modules"]
  }
  